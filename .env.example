# AumOS Video Engine — Environment Variables
# Copy to .env for local development

# Service identity
AUMOS_SERVICE_NAME=aumos-video-engine
AUMOS_ENV=development
AUMOS_LOG_LEVEL=INFO

# Database (Postgres)
DATABASE_URL=postgresql+asyncpg://aumos:aumos@localhost:5432/aumos_video

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=aumos-video-engine

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3-compatible object storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aumos-video-artifacts
MINIO_USE_SSL=false

# GPU
GPU_ENABLED=false
CUDA_DEVICE=0

# Upstream service URLs
PRIVACY_ENGINE_URL=http://localhost:8010
IMAGE_ENGINE_URL=http://localhost:8009

# JWT Auth (shared with platform-core)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Video generation settings
AUMOS_VIDEO_DEFAULT_FPS=24
AUMOS_VIDEO_DEFAULT_RESOLUTION=1280x720
AUMOS_VIDEO_MAX_FRAMES=300
AUMOS_VIDEO_MAX_BATCH_SIZE=50
AUMOS_VIDEO_STORAGE_PREFIX=video-jobs

# Stable Video Diffusion
SVD_MODEL_ID=stabilityai/stable-video-diffusion-img2vid-xt
SVD_CACHE_DIR=/tmp/model-cache

# Temporal coherence thresholds
TEMPORAL_COHERENCE_MIN_SCORE=0.7
TEMPORAL_COHERENCE_WINDOW_FRAMES=8
